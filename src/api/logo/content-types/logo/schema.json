{
  "kind": "collectionType",
  "collectionName": "logos",
  "info": {
    "singularName": "logo",
    "pluralName": "logos",
    "displayName": "Global · Logo",
    "description": "Used on: /, /spenden, /unternehmen, /universitaeten (filter by category)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "url": {
      "type": "string"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "press",
        "sponsor",
        "partner",
        "donor"
      ]
    },
    "order": {
      "type": "integer"
    }
  }
}
