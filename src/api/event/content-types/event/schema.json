{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "date"
    },
    "endDate": {
      "type": "datetime"
    },
    "location": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "memberOnly": {
      "type": "boolean"
    },
    "registrationLink": {
      "type": "string"
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "upcoming",
        "past"
      ]
    }
  }
}
